# Copy to .env (gitignored) and fill in, or export these in your shell.
# Create a Spotify app at https://developer.spotify.com/dashboard, add redirect
# URI http://127.0.0.1:8888/callback, and add your account to the app's user list
# (Spotify requires a manual allowlist — see README "Setup").

MOODMIXER_SPOTIFY_CLIENT_ID=your-client-id
MOODMIXER_SPOTIFY_CLIENT_SECRET=your-client-secret
MOODMIXER_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: a free GetSongBPM key improves tempo coverage for newer/niche tracks
# that AcousticBrainz doesn't have. https://getsongbpm.com/api
MOODMIXER_GETSONGBPM_KEY=

# Optional: where the token, library cache, and features DB live (default ~/.mood-mixer)
# MOODMIXER_DATA_DIR=
